doctype html

html(lang= config.language)
  head
    != partial('components/head')

  body(bg-style=is_home() && theme.banner.image.is_fixed ? 'fixed' : 'none' data-barba="wrapper")
    if is_post() && theme.post.progress_bar
      != partial('pages/post/post-progressbar')

    != partial('components/header')

    //- 关键 1：主内容区域，加上 barba 的标记
    main(data-barba="container" data-barba-namespace="page")
      != body

      if theme.toolbar.enable
        != partial('components/toolbar')
      
      if theme.search.enable
        != partial('components/search')
      
    //- 关键 2：音乐播放器提取到 main 的外部！保证切页时它呆在原地不动
    if theme.music.enable
      #music-player

    footer
      != partial('components/footer')

    != partial('components/scripts')